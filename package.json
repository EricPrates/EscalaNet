{
  "name": "escalanet",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "start": "cross-env NODE_ENV=production node dist/server.js",
    "typeorm": "typeorm-ts-node-commonjs",
    "migrate:generate": "npm run typeorm -- migration:generate -d src/data-source.ts",
    "migrate:run": "npm run typeorm -- migration:run -d src/data-source.ts",
    "migrate:revert": "npm run typeorm -- migration:revert -d src/data-source.ts",
    "dev": "ts-node src/server.ts",
    "test-db": "ts-node -e \"require('./src/data-source').AppDataSource.initialize().then(() => console.log('Conectado!')).catch(console.error)\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EricPrates/EscalaNet.git"
  },
